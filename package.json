{
  "name": "graduation-project-multi-agent-qa",
  "private": true,
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:server dev:web",
    "dev:server": "npm --workspace server run dev",
    "dev:web": "npm --workspace web run dev",
    "lint": "npm-run-all -p lint:server lint:web",
    "lint:server": "npm --workspace server run lint",
    "lint:web": "npm --workspace web run lint",
    "build": "npm-run-all build:server build:web",
    "build:server": "npm --workspace server run build",
    "build:web": "npm --workspace web run build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  }
}
